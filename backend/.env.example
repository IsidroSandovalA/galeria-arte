# Copia este archivo como .env y llena los valores

# Conexión a PostgreSQL (Railway la genera automáticamente)
DATABASE_URL=postgresql://usuario:password@host:5432/railway

# Poner en 'false' solo si la BD no usa SSL (por ejemplo, Postgres local)
DATABASE_SSL=true

# Puerto del servidor (Railway lo asigna solo; local usa 5000)
PORT=5000

# URL pública del backend (en Railway: https://tuapp.up.railway.app)
BASE_URL=http://localhost:5000

# Origen permitido para CORS (en producción: https://tugaleria.vercel.app)
CORS_ORIGIN=http://localhost:5173

# Tamaño máximo de archivo en bytes (10MB)
MAX_FILE_SIZE=10485760

# Credenciales del artista (login del panel)
ARTIST_USER=elige-un-usuario
ARTIST_PASSWORD=elige-una-contraseña-fuerte
# Cadena larga y aleatoria para firmar los tokens de sesión
JWT_SECRET=cadena-aleatoria-larga
